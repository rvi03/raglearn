# Copy to .env and adjust. Consumed by docker compose (infra/compose.yaml).

# Environment profile selected by the API (config.<env>.yaml).
FINRAG_ENV=dev

# Postgres
POSTGRES_USER=finrag
POSTGRES_PASSWORD=finrag
POSTGRES_DB=finrag

# MinIO object store
MINIO_ROOT_USER=finrag
MINIO_ROOT_PASSWORD=finrag-secret

# Event-driven ingestion: uploads to this bucket are published to this Redpanda
# topic, which triggers the pipeline. Broker is reachable in-network at :9092,
# from the host at :19092.
INGEST_BUCKET=filings
INGEST_TOPIC=finrag-ingest
REDPANDA_BROKER=finrag-redpanda:9092

# Ingestion: chunks embedded per forward pass. Lower = quieter/cooler/slower,
# higher = faster/hotter. Defaults to 3 (config.yaml); uncomment to override.
# FINRAG_EMBED_BATCH_SIZE=3

# Observability: only needed when `observability.exporters` includes `langfuse`.
# Langfuse OTLP ingestion authenticates with the project key pair (HTTP Basic).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# FINRAG_LANGFUSE_URL=http://finrag-langfuse:3000
