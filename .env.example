# Copy to .env and adjust. Consumed by docker compose (infra/compose.yaml).

# Environment profile selected by the API (config.<env>.yaml).
RAGLEARN_ENV=dev

# Postgres
POSTGRES_USER=raglearn
POSTGRES_PASSWORD=raglearn
POSTGRES_DB=raglearn

# MinIO object store
MINIO_ROOT_USER=raglearn
MINIO_ROOT_PASSWORD=raglearn-secret

# Event-driven ingestion: uploads to this bucket are published to this Redpanda
# topic, which triggers the pipeline. Broker is reachable in-network at :9092,
# from the host at :19092.
INGEST_BUCKET=filings
INGEST_TOPIC=raglearn-ingest
REDPANDA_BROKER=raglearn-redpanda:9092
